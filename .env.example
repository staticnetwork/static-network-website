# Public browser configuration. These are safe to expose in the Vite bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_STATIC_BETA_MODE=true
# Local development only. Never set true in production.
VITE_STATIC_DEV_MODE=false

# Server-only provider credentials. Configure these in Netlify, never VITE_*.
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_AI_TEXT_MODEL=
STATIC_AI_FREE_WEEKLY_LIMIT=3
STATIC_AI_PLUS_WEEKLY_LIMIT=30
STATIC_AI_OWNER_WEEKLY_LIMIT=100
STATIC_IMAGE_PROVIDER=
ELEVENLABS_API_KEY=
ELEVENLABS_SAGE_VOICE_ID=
ELEVENLABS_SAGE_VOICE_LABEL=
ELEVENLABS_ENTITY_VOICE_ID=
TALKING_AVATAR_PROVIDER=
DID_API_KEY=
TAVUS_API_KEY=
HEYGEN_API_KEY=
HEYGEN_SAGE_AVATAR_ID=
RUNWAY_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Server-only commerce. Required before Static+, Static Coins, or paid Store
# checkout can go live.
STATIC_APP_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STATIC_PLUS_PRICE_ID=
STRIPE_CREATOR_PRO_PRICE_ID=
STRIPE_COINS_500_PRICE_ID=
STRIPE_COINS_2500_PRICE_ID=
STRIPE_COINS_10000_PRICE_ID=
SUPABASE_SERVICE_ROLE_KEY=
